---
/**
 * The Wall.
 *
 * SSR shell that fetches the initial asset list server-side so the page can
 * paint media on first frame (no JS-blocking initial load). The React island
 * takes over for SSE + rotation + pre-cache + fullscreen behavior.
 */
import WallIsland from '@/components/secondline/WallIsland';
import { getEventBySlug } from '@/lib/secondline/events';
import { listAssetsForEvent } from '@/lib/secondline/assets';
import { isValidSlugShape } from '@/lib/secondline/slugs';
import { renderQrSvg } from '@/lib/secondline/qr';
import { getEnv } from '@/lib/env';
import { getMessages, resolveLocale } from '@/lib/i18n';
import type { PublicAsset, AssetRow } from '@/lib/secondline/types';

export const prerender = false;

const slug = Astro.params.slug ?? '';
if (!isValidSlugShape(slug)) return Astro.redirect('/404');
const event = getEventBySlug(slug);
if (!event) return Astro.redirect('/404');
if (event.status === 'expired') {
  if (event.pictime_gallery_url) return Astro.redirect(event.pictime_gallery_url);
  return Astro.redirect('/404');
}

const rows = listAssetsForEvent(event.id);
const initialAssets: PublicAsset[] = rows.map((r: AssetRow) => ({
  id: r.id,
  src: `/m/${slug}/${r.id}`,
  thumb: r.thumb_storage_key ? `/m/${slug}/${r.id}_thumb` : `/m/${slug}/${r.id}`,
  mime_type: r.mime_type,
  width: r.width, height: r.height, duration_ms: r.duration_ms,
  uploader_name: r.uploader_name, uploaded_at: r.uploaded_at,
}));
const initialSince = rows.length ? rows[rows.length - 1].uploaded_at : new Date().toISOString();
const isKiosk = Astro.url.searchParams.get('kiosk') === '1';

const showQr = !event.wall_hide_qr;
const base = getEnv('SECONDLINE_PUBLIC_URL') || 'https://secondline.smile-nola.com';
const qrSvg = showQr ? await renderQrSvg(`${base}/u/${slug}`, { size: 180 }) : null;

const locale = resolveLocale(Astro.request, event.language);
const t = getMessages(locale);
---
<!doctype html>
<html lang={locale}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="robots" content="noindex" />
    <title>{t.wall.pageTitle}</title>
    <style>
      :root { color-scheme: dark; }
      html, body { margin: 0; padding: 0; background: #050505; color: #f8f4ea; height: 100%; overflow: hidden;
                   font-family: system-ui, sans-serif; }
      #wall-root { position: fixed; inset: 0; }
    </style>
  </head>
  <body>
    <div id="wall-root">
      <WallIsland client:load slug={slug} initialAssets={initialAssets} initialSince={initialSince} kiosk={isKiosk}
                  dwellMs={event.wall_dwell_ms} crossfadeMs={event.wall_crossfade_ms}
                  videoMaxMs={event.wall_video_max_ms} videoFull={!!event.wall_video_full}
                  hideBg={!!event.wall_hide_bg} hideCaption={!!event.wall_hide_caption}
                  transition={event.wall_transition} locale={locale}
                  bgUrl={event.wall_bg_key ? `/m/${slug}/bg?v=${encodeURIComponent(event.wall_bg_key)}` : null} />
    </div>
    {showQr && (
      <div class="wall-qr">
        <p>{t.wall.scanToView}</p>
        <div class="wall-qr-code" set:html={qrSvg}></div>
      </div>
    )}
    <div class="wall-badge">
      <span class="heart">♥</span>
      <span>{t.common.madeWith}</span>
      <span class="brand">Smile NOLA</span>
    </div>
    {/* is:global — Astro's scoped-style hash does not get applied to these
        conditionally rendered overlays, so scoped selectors silently never
        match (the QR rendered unstyled and was painted over by the wall). */}
    <style is:global>
      .wall-qr { position: fixed; left: 10px; bottom: 10px; z-index: 10; text-align: left;
                 --qr-w: clamp(160px, 16vw, 380px); }
      .wall-qr p { margin: 0 0 8px; padding: 8px 10px; display: block; width: var(--qr-w);
                   box-sizing: border-box; background: rgba(0,0,0,0.55); text-align: center;
                   color: #fff; font-size: clamp(14px, 1.5vw, 27px); font-weight: 700; line-height: 1.25; }
      .wall-qr-code { background: #fff; border: 3px solid #d4af37; border-radius: 8px; padding: 8px;
                      width: var(--qr-w); box-sizing: border-box;
                      box-shadow: 0 4px 18px rgba(0,0,0,0.5); }
      .wall-qr-code svg { width: 100%; height: auto; display: block; }
      .wall-badge { position: fixed; top: 12px; left: 12px; z-index: 10; display: flex; align-items: center;
                    justify-content: center; gap: 0.5em; width: clamp(160px, 16vw, 380px);
                    box-sizing: border-box; background: rgba(0,0,0,0.65); border-radius: 999px;
                    padding: 0.55em 1em; font-size: clamp(13px, 1.2vw, 22px); }
      .wall-badge .heart { color: #d4af37; font-size: 1.1em; line-height: 1; }
      .wall-badge span { color: #f8f4ea; white-space: nowrap; }
      .wall-badge .brand { color: #d4af37; font-family: Georgia, serif; font-weight: 700;
                           letter-spacing: 0.06em; }
    </style>
  </body>
</html>
