---
/**
 * Marketing home page for Second Line.
 *
 * This is the only public URL someone can reach WITHOUT a QR code or a shared
 * link, so it does the marketing job: sell the live photo wall to prospective
 * hosts. The showpiece is a self-contained {@link DemoWall} island looping
 * curated stock event photos — the product in motion, with no event/DB behind
 * it. Guest "find my gallery" tooling is a separate, later effort.
 */
import DemoWall from '@/components/secondline/DemoWall';
import SecondLineLogo from '@/components/secondline/SecondLineLogo.astro';
import LangToggle from '@/components/secondline/LangToggle.astro';
import { getMessages, resolveLocale } from '@/lib/i18n';

export const prerender = false;

const locale = resolveLocale(Astro.request);
const t = getMessages(locale).landing;

const year = new Date().getFullYear();
const BOOK_URL = 'https://smile-nola.com/contact';

// Curated wedding-reception / party stock photos (Unsplash License: free for
// commercial use, no attribution), bundled under /public/demo.
const demoImages = [8, 1, 6, 2, 10, 3, 7, 4, 9].map(n => `/demo/demo-${n}.jpg`);
// Fake uploader names cycled with the photos to sell the live-share feel.
const demoNames = ['Marie', 'DJ Tee', 'Aunt Rose', 'The Beauchamps', 'Andre', 'Camille', 'Big Mike', 'Yvette', 'The DJ'];

const faqs = t.faqs;
---

<!doctype html>
<html lang={locale}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="color-scheme" content="dark" />
    <title>{t.metaTitle}</title>
    <meta name="description" content={t.metaDescription} />
    <link rel="canonical" href="https://secondline.smile-nola.com/" />
    <meta property="og:type" content="website" />
    <meta property="og:title" content={t.ogTitle} />
    <meta property="og:description" content={t.ogDescription} />
    <meta property="og:url" content="https://secondline.smile-nola.com/" />
    <meta property="og:image" content="https://secondline.smile-nola.com/demo/demo-6.jpg" />
    <meta name="twitter:card" content="summary_large_image" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Oswald:wght@500;600;700&display=swap" rel="stylesheet" />
    <style>
      :root {
        --bg: #0a0a0a;
        --bg-soft: #141014;
        --ink: #f5f3ee;
        --muted: #a39f97;
        --gold: #d4af37;
        --line: rgba(212, 175, 55, 0.18);
        --maxw: 70rem;
      }
      * { box-sizing: border-box; }
      html, body { margin: 0; padding: 0; }
      html { scroll-behavior: smooth; }
      body {
        background: var(--bg);
        color: var(--ink);
        font-family: ui-sans-serif, system-ui, -apple-system, "Segoe UI", Roboto, sans-serif;
        line-height: 1.55;
        -webkit-font-smoothing: antialiased;
      }
      .wrap { width: 100%; max-width: var(--maxw); margin: 0 auto; padding: 0 1.5rem; }
      a { color: inherit; }

      /* --- Buttons --- */
      .btn {
        display: inline-flex; align-items: center; justify-content: center; gap: 0.5em;
        font-size: 1rem; font-weight: 600; line-height: 1; text-decoration: none;
        padding: 0.9em 1.5em; border-radius: 999px; border: 1px solid transparent;
        cursor: pointer; transition: transform 0.15s ease, background 0.15s ease, border-color 0.15s ease;
      }
      .btn-primary { background: var(--gold); color: #1a1206; }
      .btn-primary:hover { transform: translateY(-2px); background: #e4bf47; }
      .btn-ghost { background: transparent; color: var(--ink); border-color: var(--line); }
      .btn-ghost:hover { transform: translateY(-2px); border-color: var(--gold); color: var(--gold); }

      /* --- Header --- */
      header.site {
        position: sticky; top: 0; z-index: 50;
        background: rgba(10, 10, 10, 0.72);
        backdrop-filter: blur(12px);
        border-bottom: 1px solid var(--line);
      }
      .nav { display: flex; align-items: center; justify-content: space-between; height: 4.5rem; }
      .nav .nav-actions { display: flex; align-items: center; gap: 0.85rem; }
      .nav .logo { display: flex; align-items: center; text-decoration: none; }
      .nav .logo .by { margin-left: 0.85rem; padding-left: 0.85rem; border-left: 1px solid var(--line);
                       font-size: 0.72rem; letter-spacing: 0.16em; text-transform: uppercase; color: var(--muted); }
      @media (max-width: 560px) { .nav .logo .by { display: none; } }

      /* --- Hero --- */
      .hero { padding: 3.5rem 0 4rem; }
      .hero-grid { display: grid; grid-template-columns: 1.05fr 1fr; gap: 3rem; align-items: center; }
      .eyebrow { font-size: 0.78rem; letter-spacing: 0.22em; text-transform: uppercase; color: var(--gold); margin: 0 0 1.1rem; }
      .brand-h1 { margin: 0 0 0.85rem; line-height: 1; }
      .by-line { display: flex; align-items: center; gap: 0.55rem; margin: 0 0 1.75rem;
                 font-size: 0.8rem; letter-spacing: 0.14em; text-transform: uppercase; color: var(--muted); }
      .by-line .smile-mark { height: 1.5rem; width: auto; display: inline-block; }
      .by-line .sep { color: var(--muted); }
      .hero-tagline { font-size: clamp(1.5rem, 3.2vw, 2.2rem); font-weight: 600; letter-spacing: -0.01em;
                      line-height: 1.12; margin: 0 0 1.25rem; }
      .hero-tagline .accent { color: var(--gold); }
      .hero .lede { color: var(--muted); font-size: 1.15rem; max-width: 34rem; margin: 0 0 2rem; }
      .hero .cta-row { display: flex; flex-wrap: wrap; gap: 0.85rem; }

      /* --- Demo "screen" frame --- */
      .screen {
        position: relative; width: 100%; aspect-ratio: 16 / 10;
        border-radius: 16px; overflow: hidden;
        background: #050505;
        border: 1px solid rgba(212, 175, 55, 0.25);
        box-shadow: 0 30px 80px rgba(0,0,0,0.6), 0 0 0 1px rgba(0,0,0,0.5) inset;
      }
      .screen-stand { width: 38%; height: 0.7rem; margin: 0.6rem auto 0; border-radius: 0 0 8px 8px;
                      background: linear-gradient(180deg, #1a1a1a, #0c0c0c); border: 1px solid #1f1f1f; border-top: none; }
      .screen-cap { text-align: center; color: var(--muted); font-size: 0.85rem; margin-top: 0.9rem; }

      @media (max-width: 820px) {
        .hero-grid { grid-template-columns: 1fr; gap: 2.25rem; }
        .hero .lede { max-width: none; }
      }

      /* --- Sections --- */
      section.band { padding: 4.5rem 0; border-top: 1px solid var(--line); }
      .section-head { text-align: center; max-width: 38rem; margin: 0 auto 3rem; }
      .section-head h2 { font-size: clamp(1.8rem, 3.5vw, 2.6rem); font-weight: 700; letter-spacing: -0.01em; margin: 0 0 0.75rem; }
      .section-head p { color: var(--muted); font-size: 1.08rem; margin: 0; }

      /* --- Steps --- */
      .steps { display: grid; grid-template-columns: repeat(3, 1fr); gap: 1.5rem; }
      .step { background: var(--bg-soft); border: 1px solid var(--line); border-radius: 14px; padding: 2rem 1.6rem; }
      .step .num { display: inline-flex; align-items: center; justify-content: center; width: 2.4rem; height: 2.4rem;
                   border-radius: 999px; background: rgba(212,175,55,0.12); color: var(--gold);
                   font-weight: 700; font-size: 1.1rem; margin-bottom: 1.1rem; }
      .step h3 { font-size: 1.2rem; margin: 0 0 0.5rem; }
      .step p { color: var(--muted); margin: 0; font-size: 0.98rem; }
      @media (max-width: 720px) { .steps { grid-template-columns: 1fr; } }

      /* --- FAQ --- */
      .faq { max-width: 44rem; margin: 0 auto; }
      .faq details { border-bottom: 1px solid var(--line); padding: 1.25rem 0; }
      .faq summary { cursor: pointer; list-style: none; font-weight: 600; font-size: 1.1rem;
                     display: flex; justify-content: space-between; align-items: center; gap: 1rem; }
      .faq summary::-webkit-details-marker { display: none; }
      .faq summary .plus { color: var(--gold); font-size: 1.4rem; line-height: 1; transition: transform 0.2s ease; }
      .faq details[open] summary .plus { transform: rotate(45deg); }
      .faq details p { color: var(--muted); margin: 0.85rem 0 0; max-width: 40rem; }

      /* --- CTA band --- */
      .cta-band { text-align: center; background:
        radial-gradient(120% 120% at 50% 0%, rgba(212,175,55,0.10), transparent 60%), var(--bg-soft); }
      .cta-band h2 { font-size: clamp(1.9rem, 4vw, 2.8rem); font-weight: 700; margin: 0 0 1rem; }
      .cta-band p { color: var(--muted); font-size: 1.12rem; margin: 0 auto 2rem; max-width: 34rem; }

      /* --- Footer --- */
      footer.site { border-top: 1px solid var(--line); padding: 2.5rem 0; }
      .foot { display: flex; flex-wrap: wrap; align-items: center; justify-content: space-between; gap: 1rem;
              color: var(--muted); font-size: 0.85rem; }
      .foot .brand { color: var(--gold); font-family: Georgia, serif; font-weight: 700; letter-spacing: 0.05em; }
      .foot a.admin { color: var(--muted); text-decoration: none; opacity: 0.7; }
      .foot a.admin:hover { color: var(--gold); opacity: 1; }
    </style>
  </head>
  <body>
    <header class="site">
      <div class="wrap nav">
        <a class="logo" href="/" aria-label="Second Line by Smile NOLA">
          <SecondLineLogo size="1.15rem" />
          <span class="by">by Smile NOLA</span>
        </a>
        <div class="nav-actions">
          <LangToggle locale={locale} />
          <a class="btn btn-primary" href={BOOK_URL}>{t.bookEvent}</a>
        </div>
      </div>
    </header>

    <main>
      <!-- Hero -->
      <section class="hero">
        <div class="wrap hero-grid">
          <div>
            <h1 class="brand-h1"><SecondLineLogo size="clamp(3rem, 8vw, 5.5rem)" /></h1>
            <p class="by-line">
              by <img class="smile-mark" src="/smile-nola-logo.svg" alt="Smile NOLA" />
              <span class="sep">· {t.location}</span>
            </p>
            <p class="hero-tagline">{t.taglineLead} <span class="accent">{t.taglineAccent}</span></p>
            <p class="lede">{t.lede}</p>
            <div class="cta-row">
              <a class="btn btn-primary" href={BOOK_URL}>{t.ctaBook}</a>
              <a class="btn btn-ghost" href="#how">{t.ctaSeeHow}</a>
            </div>
          </div>
          <div>
            <div class="screen">
              <DemoWall client:load images={demoImages} names={demoNames} locale={locale} />
            </div>
            <div class="screen-stand"></div>
            <p class="screen-cap">{t.screenCaption}</p>
          </div>
        </div>
      </section>

      <!-- How it works -->
      <section class="band" id="how">
        <div class="wrap">
          <div class="section-head">
            <h2>{t.howTitle}</h2>
            <p>{t.howSub}</p>
          </div>
          <div class="steps">
            <div class="step">
              <span class="num">1</span>
              <h3>{t.step1Title}</h3>
              <p>{t.step1Body}</p>
            </div>
            <div class="step">
              <span class="num">2</span>
              <h3>{t.step2Title}</h3>
              <p>{t.step2Body}</p>
            </div>
            <div class="step">
              <span class="num">3</span>
              <h3>{t.step3Title}</h3>
              <p>{t.step3Body}</p>
            </div>
          </div>
        </div>
      </section>

      <!-- FAQ -->
      <section class="band">
        <div class="wrap">
          <div class="section-head">
            <h2>{t.faqTitle}</h2>
            <p>{t.faqSub}</p>
          </div>
          <div class="faq">
            {faqs.map((f) => (
              <details>
                <summary>{f.q}<span class="plus">+</span></summary>
                <p>{f.a}</p>
              </details>
            ))}
          </div>
        </div>
      </section>

      <!-- Closing CTA -->
      <section class="band cta-band">
        <div class="wrap">
          <h2>{t.ctaBandTitle}</h2>
          <p>{t.ctaBandSub}</p>
          <a class="btn btn-primary" href={BOOK_URL}>{t.ctaBook}</a>
        </div>
      </section>
    </main>

    <footer class="site">
      <div class="wrap foot">
        <span>{t.footerMadeBy} <span style="color: var(--gold)">♥</span> {t.footerBy} <span class="brand">Smile NOLA</span> · &copy; {year}</span>
        <a class="admin" href="/admin">{t.admin}</a>
      </div>
    </footer>
  </body>
</html>
