{
  "name": "secondline-app",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.33.2",
  "scripts": {
    "dev": "node --env-file-if-exists=.env ./node_modules/astro/astro.js dev",
    "dev:lan": "node --env-file-if-exists=.env ./node_modules/astro/astro.js dev --host 0.0.0.0",
    "build": "astro build",
    "preview": "astro preview",
    "start": "node ./dist/server/entry.mjs",
    "typecheck": "astro check",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@astrojs/node": "^9.1.3",
    "@astrojs/react": "^4.4.2",
    "@aws-sdk/client-s3": "^3.700.0",
    "@tailwindcss/vite": "^4.0.0",
    "archiver": "^7.0.1",
    "astro": "^5.1.0",
    "qrcode": "^1.5.4",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "resend": "^4.8.0",
    "sharp": "^0.34.5",
    "tailwindcss": "^4.0.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.4",
    "@types/archiver": "^6.0.3",
    "@types/node": "^22.0.0",
    "@types/qrcode": "^1.5.5",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "typescript": "^5.7.3",
    "vitest": "^3.2.4"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "sharp"
    ]
  },
  "engines": {
    "node": ">=22.5.0"
  }
}
