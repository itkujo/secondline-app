# Second Line — staging env template (CasaOS on ZimaBlade, Tailscale-fronted)
#
# Copy this to .env in the staging app directory on the ZimaBlade:
#   /var/lib/casaos/apps/secondline-staging/.env
# Fill in every <PLACEHOLDER>. Do NOT commit the filled-in .env anywhere.
#
# Differences from prod:
#  - SECONDLINE_PUBLIC_URL / MEDIA_PUBLIC_URL point at the Tailscale-fronted host
#  - SECONDLINE_ACTIVE_BACKEND is `wasabi-staging` (separate Wasabi bucket)
#  - WASABI_STAGING_* creds replace WASABI_*
#  - No prod WASABI_* credentials → backends.ts skips that entry with a warn
#  - SECONDLINE_CRON_TOKEN is set but no scheduled tasks fire it; you trigger
#    /api/cron/cleanup and /api/cron/reminders manually with curl during
#    Task 32 step 6/7

# --- Public origins ----------------------------------------------------------

# What URL the app thinks it's served at. Both can be the same in staging
# since you're not splitting media onto a separate subdomain.
SECONDLINE_PUBLIC_URL=https://secondline-staging.<your-tailnet>.ts.net
MEDIA_PUBLIC_URL=https://secondline-staging.<your-tailnet>.ts.net

# --- Admin auth --------------------------------------------------------------

# Pick something you can type on a phone. Not a prod password.
ADMIN_PASSWORD=<PICK_STAGING_PASSWORD>

# HMAC key for the session cookie. Generate with:  openssl rand -hex 32
ADMIN_SESSION_SECRET=<RAND_HEX_32>

# --- Email -------------------------------------------------------------------

# Real Resend so you can verify gallery-ready / expiry / expired templates
# in your own inbox. Domain MUST be verified in Resend (or use
# onboarding@resend.dev to only deliver to your verified account address).
RESEND_API_KEY=re_<YOUR_KEY>
RESEND_FROM=Smile NOLA Staging <staging@your-verified-domain>

# --- Storage -----------------------------------------------------------------

# Use the staging backend defined in secondline-backends.json. NEVER point
# this at the prod `wasabi` id from staging.
SECONDLINE_ACTIVE_BACKEND=wasabi-staging

# IAM creds scoped to ONLY the secondline-staging bucket in Wasabi.
WASABI_STAGING_ACCESS_KEY=<STAGING_ACCESS_KEY>
WASABI_STAGING_SECRET_KEY=<STAGING_SECRET_KEY>

# --- Cron --------------------------------------------------------------------

# Bearer token for /api/cron/cleanup and /api/cron/reminders. Without this
# set, those endpoints return 503 ("cron not configured"). No scheduled task
# fires them in staging; you call them manually with curl during testing.
# Generate with: openssl rand -hex 32
SECONDLINE_CRON_TOKEN=<RAND_HEX_32>

# --- DB ---------------------------------------------------------------------- 

# The Dockerfile already sets this to /data and the compose file mounts a
# host directory there. Override only if you know what you're doing.
# SECONDLINE_DB_DIR=/data
