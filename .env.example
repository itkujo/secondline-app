# --- App ---
PORT=3000
SECONDLINE_PUBLIC_URL=https://secondline.smile-nola.com
MEDIA_PUBLIC_URL=https://media.smile-nola.com

# --- Admin auth (single-password) ---
ADMIN_PASSWORD=
ADMIN_SESSION_SECRET=

# --- DB ---
# Where leads.db (and uploads/) live. Defaults to ./data in dev,
# /data (Coolify named volume) in prod.
SECONDLINE_DB_DIR=

# --- Email (Resend) ---
RESEND_API_KEY=
RESEND_FROM=
NOTIFY_EMAIL=

# --- Storage backends (registry) ---
# Active default for newly-created events.
SECONDLINE_ACTIVE_BACKEND=wasabi
# Wasabi (default backend in secondline-backends.json)
WASABI_ACCESS_KEY=
WASABI_SECRET_KEY=

# --- Scheduled tasks ---
SECONDLINE_CRON_TOKEN=
